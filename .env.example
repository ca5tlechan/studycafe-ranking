# 로컬 개발용 환경변수 예시.
# 실제 값은 이 파일을 .env 로 복사해서 채운다. .env 는 gitignore 되어 커밋되지 않는다.

# --- Database (docker-compose.yml 의 Postgres 와 일치) ---
DB_URL=jdbc:postgresql://localhost:5433/studycafe
DB_USERNAME=studycafe
DB_PASSWORD=studycafe

# --- Auth (필수) ---
# JWT 서명 키. 최소 32바이트 이상의 랜덤 문자열. 기본값이 없어 미설정 시 앱이 기동되지 않는다(fail-fast).
# 예시 생성: openssl rand -base64 48
JWT_SECRET=local-dev-only-replace-with-random-string-min-32-bytes
