# 로컬 개발용 환경변수 예시.
# 실제 값은 이 파일을 .env 로 복사해서 채운다. .env 는 gitignore 되어 커밋되지 않는다.

# --- Database (docker-compose.yml 의 Postgres 와 일치) ---
DB_URL=jdbc:postgresql://localhost:5432/studycafe
DB_USERNAME=studycafe
DB_PASSWORD=studycafe

# --- Auth (Phase 1 에서 사용) ---
# JWT 서명 키. 최소 32바이트 이상의 랜덤 문자열로 채울 것.
# JWT_SECRET=change-me-to-a-long-random-secret
